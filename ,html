<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Coffee Shop</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)),
                        url('https://images.unsplash.com/photo-1509042239860-f550ce710b93');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }

        .container {
            width: 900px;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            display: flex;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.5s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .left {
            flex: 1;
            background: linear-gradient(rgba(111, 78, 55, 0.8), rgba(111, 78, 55, 0.8)),
                        url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085');
            background-size: cover;
            background-position: center;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
            text-align: center;
        }

        .left h1 {
            font-size: 42px;
            margin-bottom: 15px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        }

        .left p {
            font-size: 16px;
            line-height: 1.8;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.3);
        }

        .right {
            flex: 1;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .logo {
            text-align: center;
            font-size: 50px;
            margin-bottom: 10px;
        }

        .right h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #6F4E37;
            font-size: 28px;
        }

        .input-group {
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 500;
        }

        .input-group input {
            width: 100%;
            padding: 13px 15px;
            border: 2px solid #ddd;
            border-radius: 10px;
            outline: none;
            font-size: 14px;
            transition: 0.3s;
        }

        .input-group input:focus {
            border-color: #6F4E37;
            box-shadow: 0 0 8px rgba(111, 78, 55, 0.2);
        }

        .input-group input.error {
            border-color: #e74c3c;
            background-color: #fadbd8;
        }

        .error-message {
            color: #e74c3c;
            font-size: 12px;
            margin-top: 5px;
            display: none;
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            border: none;
            background: #6F4E37;
            color: white;
            font-size: 16px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-login:hover {
            background: #4e342e;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(111, 78, 55, 0.3);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .links {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #666;
        }

        .links a {
            text-decoration: none;
            color: #6F4E37;
            font-weight: 600;
            transition: 0.3s;
        }

        .links a:hover {
            color: #8B6F47;
            text-decoration: underline;
        }

        .demo {
            margin-top: 25px;
            text-align: center;
            background: #f5f5f5;
            padding: 15px;
            border-radius: 10px;
            font-size: 13px;
            border: 1px solid #e0e0e0;
        }

        .demo b {
            color: #6F4E37;
            display: block;
            margin-bottom: 8px;
        }

        .demo p {
            margin: 5px 0;
            color: #555;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: #6F4E37;
            text-decoration: none;
            font-weight: 500;
            transition: 0.3s;
        }

        .back-link:hover {
            color: #8B6F47;
        }

        @media (max-width: 768px) {
            .container {
                width: 95%;
                flex-direction: column;
            }

            .left {
                padding: 30px;
                min-height: 300px;
            }

            .left h1 {
                font-size: 32px;
            }

            .right {
                padding: 30px;
            }

            .right h2 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Left Side -->
        <div class="left">
            <h1>☕ Coffee Shop</h1>
            <p>
                <strong>Fresh Coffee Every Day</strong>
                <br><br>
                Nikmati kopi premium dengan cita rasa terbaik
                yang dibuat dari biji kopi pilihan Indonesia.
                <br><br>
                Setiap tegukan adalah pengalaman yang tak terlupakan.
            </p>
        </div>

        <!-- Right Side -->
        <div class="right">
            <a href="../index.html" class="back-link">← Kembali ke Home</a>

            <div class="logo">☕</div>
            <h2>Login Account</h2>

            <form id="loginForm">
                <div class="input-group">
                    <label for="email">📧 Email</label>
                    <input type="email" id="email" name="email" placeholder="Masukkan email Anda" required>
                    <div class="error-message"></div>
                </div>

                <div class="input-group">
                    <label for="password">🔒 Password</label>
                    <input type="password" id="password" name="password" placeholder="Masukkan password Anda" required>
                    <div class="error-message"></div>
                </div>

                <button type="submit" class="btn-login">Login</button>
            </form>

            <div class="links">
                Belum punya akun?
                <a href="register.html">Daftar Sekarang</a>
            </div>

            <div class="demo">
                <b>Demo Login</b>
                <p><strong>Email:</strong> najaemin13@gmail.com</p>
                <p><strong>Password:</strong> jaeminnaa13</p>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById('loginForm');
        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');

        // Function validasi email
        function isValidEmail(email) {
            const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            return regex.test(email);
        }

        // Function tampil error
        function showError(input, message) {
            input.classList.add('error');
            const errorDiv = input.nextElementSibling;
            if (errorDiv && errorDiv.classList.contains('error-message')) {
                errorDiv.textContent = message;
                errorDiv.style.display = 'block';
            }
        }

        // Function hapus error
        function clearError(input) {
            input.classList.remove('error');
            const errorDiv = input.nextElementSibling;
            if (errorDiv && errorDiv.classList.contains('error-message')) {
                errorDiv.textContent = '';
                errorDiv.style.display = 'none';
            }
        }

        // Validasi saat form di-submit
        form.addEventListener('submit', function(e) {
            e.preventDefault();

            let isValid = true;

            // Validasi email
            if (!emailInput.value.trim()) {
                showError(emailInput, '❌ Email tidak boleh kosong');
                isValid = false;
            } else if (!isValidEmail(emailInput.value)) {
                showError(emailInput, '❌ Format email tidak valid');
                isValid = false;
            } else {
                clearError(emailInput);
            }

            // Validasi password
            if (!passwordInput.value.trim()) {
                showError(passwordInput, '❌ Password tidak boleh kosong');
                isValid = false;
            } else if (passwordInput.value.length < 6) {
                showError(passwordInput, '❌ Password minimal 6 karakter');
                isValid = false;
            } else {
                clearError(passwordInput);
            }

            // Jika valid, tampilkan alert sukses
            if (isValid) {
                alert('✅ Login berhasil! Anda akan diarahkan ke dashboard.');
                window.location.href = '../index.html#dashboard';
            }
        });

        // Validasi real-time saat blur
        emailInput.addEventListener('blur', function() {
            if (this.value.trim()) {
                if (!isValidEmail(this.value)) {
                    showError(this, '❌ Format email tidak valid');
                } else {
                    clearError(this);
                }
            } else {
                clearError(this);
            }
        });

        passwordInput.addEventListener('blur', function() {
            if (this.value.trim()) {
                if (this.value.length < 6) {
                    showError(this, '❌ Password minimal 6 karakter');
                } else {
                    clearError(this);
                }
            } else {
                clearError(this);
            }
        });

        // Hapus error saat user mulai mengetik
        emailInput.addEventListener('input', function() {
            if (this.classList.contains('error')) {
                clearError(this);
            }
        });

        passwordInput.addEventListener('input', function() {
            if (this.classList.contains('error')) {
                clearError(this);
            }
        });
    </script>
</body>
</html>
